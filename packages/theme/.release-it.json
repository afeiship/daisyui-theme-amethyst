{
  "git": {
    "commitMessage": "chore: release v${version}",
    "tagName": "v${version}"
  },
  "npm": {
    "publish": true
  },
  "hooks": {
    "before:init": [
      "npm run build"
    ],
    "after:release": "echo Successfully released ${name} v${version}!"
  },
  "github": {
    "release": true,
    "proxy": "http://127.0.0.1:9090"
  }
}